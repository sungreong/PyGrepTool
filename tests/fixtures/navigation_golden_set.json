              "max_results": 20,
              "hidden": false
            }
          },
          "expect": {
            "ok": true,
            "paths": ["/src/alpha_service.py", "/src/beta_service.py"]
          }
        }
      ]
    },
    {
      "id": "journey_find_backend_setting",
      "question": "smart backend 설정은 어디에 정의되어 있나? 줄 번호와 함께 알려줘.",
      "steps": [
        {
          "request": {
            "tool": "search_code",
            "arguments": {
              "pattern": "BACKEND_MODE",
              "roots": ["/src"],
              "regex": false,
              "include": ["*.py"],
              "max_results": 10,
              "include_context": false
            }
          },
          "expect": {
            "ok": true,
            "evidence": {
              "path": "/src/alpha_service.py",
