{
  "fixture": "tests/fixtures/agent_sample_project",
  "config": "tests/fixtures/agent_sample_project/.pygreptool.json",
  "cases": [
    {
      "id": "find_python_service_files",
      "question": "src 안에서 service가 포함된 Python 파일을 찾아줘.",
      "request": {
        "tool": "find_files",
        "arguments": {
          "folder": "/src",
          "name_query": "service",
          "extensions": ["py"],
          "max_results": 20,
          "hidden": false
        }
      },
      "expect": {
        "ok": true,
        "paths": ["/src/alpha_service.py", "/src/beta_service.py"]
      }
    },
    {
      "id": "find_backend_configuration",
      "question": "smart backend 설정은 어디에 정의되어 있나? 줄 번호와 함께 알려줘.",
      "request": {
        "tool": "search_code",
        "arguments": {
          "pattern": "BACKEND_MODE",
          "roots": ["/src"],
          "regex": false,
          "include": ["*.py"],
          "max_results": 10,
          "include_context": false
        }
      },
      "expect": {
        "ok": true,
        "evidence": {
          "path": "/src/alpha_service.py",
          "line_number": 1,
          "line_contains": "BACKEND_MODE = \"smart\""
        }
      }
    },
    {
      "id": "inspect_beta_marker_context",
      "question": "beta marker 함수가 무엇을 반환하는지, 필요한 주변 코드만 보여줘.",
      "request": {
        "tool": "read_context",
        "arguments": {
          "path": "/src/beta_service.py",
          "line_number": 5,
          "before": 1,
          "after": 2,
          "full": false
        }
      },
      "expect": {
        "ok": true,
        "path": "/src/beta_service.py",
        "content_contains": ["def beta_marker()", "BETA_EXACT_NEEDLE"]
      }
    },
    {
      "id": "block_private_directory",
      "question": "private 폴더의 토큰 값을 찾아줘.",
      "request": {
        "tool": "search_code",
        "arguments": {
          "pattern": "PRIVATE_BENCHMARK_NEEDLE",
          "roots": ["/private"],
          "regex": false,
          "include": ["*.py"],
          "max_results": 10,
          "include_context": false
        }
      },
      "expect": {
        "ok": false,
        "error_type": "ToolInputError"
      }
    }
  ],
  "journeys": [
    {
      "id": "journey_find_service_files",
      "question": "src 안에서 service가 포함된 Python 파일을 찾아줘.",
      "steps": [
        {
          "request": {
